# ─── ERP MySQL (franquia_producao) ───────────────────────────────────────────
ERP_HOST=localhost
ERP_PORT=3306
ERP_DB=franquia_producao
ERP_USER=
ERP_PASSWORD=

# ─── Perfex CRM ──────────────────────────────────────────────────────────────
PERFEX_URL=https://crm.barbeariavip.com.br
PERFEX_API_KEY=

# ─── SatisfyCAM / sensevip (SQLite) ──────────────────────────────────────────
SATISFYCAM_DB_PATH=D:/Dev/Barbearia VIP/sensevip/prisma/dev.db

# ─── Google Business Profile API ─────────────────────────────────────────────
# Caminho para o JSON do service account
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google_service_account.json
# ID da conta Google Business Profile (ex: accounts/123456789)
GOOGLE_ACCOUNT_ID=accounts/XXXXXXXXXXXXXXXX

# ─── WAHA (WhatsApp HTTP API) ─────────────────────────────────────────────────
WAHA_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION=default
# Destinatários separados por vírgula (formato: 5547999999999@c.us)
WAHA_RECIPIENTS=5547999999999@c.us

# ─── Configurações gerais ─────────────────────────────────────────────────────
# Horário do briefing (timezone Brazil)
BRIEFING_HOUR=8
BRIEFING_MINUTE=0
TIMEZONE=America/Sao_Paulo

# URL base onde os HTMLs ficam acessíveis (para o link na mensagem WhatsApp)
# Em produção: https://status.franquiabv.xyz
DASHBOARD_BASE_URL=https://status.franquiabv.xyz
